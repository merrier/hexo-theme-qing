{% set bg_style = "background-image: url('https://loremflickr.com/1920/400/china,landscape,painting/all?random=" + (range(1, 1000000) | random) + "'); background-size: cover; background-position: center; background-repeat: no-repeat;" %}
{% if theme.header_bg and theme.header_bg != 'random' %}
    {% if theme.header_bg.startsWith('#') or theme.header_bg.startsWith('rgb') or theme.header_bg.startsWith('rgba') %}
        {% set bg_style = "background-color: " + theme.header_bg + ";" %}
    {% else %}
        {% set bg_style = "background-image: url('" + theme.header_bg + "'); background-size: cover; background-position: center; background-repeat: no-repeat;" %}
    {% endif %}
{% endif %}
<header class="main-header" style="{{ bg_style | safe }}">
    <div class="main-header-box">
        <a class="header-avatar" href="/" title='{{ config.author }}'>
            {{ image_tag('/images/hexo_others_8.jpeg',{alt:'logo头像',class:'img-responsive center-block'}) | safe }}
        </a>
        <div class="branding">
        	<!--<h2 class="text-hide">Snippet主题,从未如此简单有趣</h2>-->
            {% if theme.branding %}
                <h2> {{ theme.branding }} </h2>
            {% else %}
                 {{ image_tag('img/branding.png',{alt:'Snippet 博客主题',class:'img-responsive center-block'}) | safe }}
            {% endif %}
    	</div>
    </div>
</header>