<div class="widget">
    <h3 class="title">日历</h3>
    <div class="content" style="padding: 0; background: transparent; box-shadow: none;">
        {% set he_route = theme.he_calendar.route or 'he-calendar/' %}
        {% set he_width = theme.he_calendar.width or '100%' %}
        {% set he_height = theme.he_calendar.height or '420px' %}
        {% set he_radius = theme.he_calendar.border_radius or '2px' %}
        
        <div class="he-calendar-wrapper" style="width: {{ he_width }}; height: {{ he_height }}; overflow: hidden; border-radius: {{ he_radius }}; margin: 0 auto;">
            <!-- 如果你的根目录配置了 he_calendar 改变了路由，这里请确保一致 -->
            <iframe src="{{ url_for(he_route + 'index.html') }}" style="width: 100%; height: 100%; border: none; border-radius: {{ he_radius }}; background: transparent;" frameborder="0" scrolling="no"></iframe>
        </div>
    </div>
</div>